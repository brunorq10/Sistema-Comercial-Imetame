generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Perfil {
  ADM_COMERCIAL
  GESTAO_COMERCIAL
  ORCAMENTISTA
  GESTAO_ACORDOS
  ACORDOS
  ADM_GERAL
}

enum StatusAnalise {
  AGUARDANDO
  APROVADA
  REPROVADA
}

enum StatusSolicitacao {
  AGUARDANDO_ANALISE
  EM_ELABORACAO
  PROPOSTA_ENVIADA
  CONTRATO_GANHO
  RECUSADA
  CANCELADA
  SUSPENSA
}

enum Classificacao {
  OBRAS
  PARADAS
  OLEO_GAS
  FABRICACOES
}

enum Interesse {
  ALTO
  MEDIO
  BAIXO
}

enum Origem {
  EMAIL
  TELEFONE
  VISITA
  INDICACAO
  OUTRO
}

enum Segmento {
  PAPEL_CELULOSE
  SIDERURGIA
  OLEO_GAS
  OUTROS
}

enum MotivoReprovacao {
  VOLUME_ADJUDICADO
  FORA_LINHA_FORNECIMENTO
  INDISPONIBILIDADE_MO
  SEM_SERVICO_LOCAL
  LIMITACAO_EQUIPAMENTOS
  DIFICULDADE_PARCERIA
  OUTROS
}

enum MotivoPerda {
  PRECO
  PRAZO
  ESCOPO
  CONCORRENCIA
  CLIENTE_DESISTIU
  OUTRO
}

enum StatusAcordo {
  ATIVO
  ENCERRADO
  CANCELADO
}

enum StatusFaturamento {
  A_FATURAR
  FATURADO
  PARCIAL
  CANCELADO
}

enum RamoAtuacao {
  PAPEL_CELULOSE
  SIDERURGIA
  MINERACAO
  OLEO_GAS
  OUTROS
}

// ─── Modelos ─────────────────────────────────────────────────────────────────

model User {
  id            Int      @id @default(autoincrement())
  nome          String
  email         String   @unique
  password_hash       String
  perfil              Perfil
  funcao              String?
  ativo               Boolean   @default(true)
  is_analista_critico Boolean   @default(false)
  deactivated_at      DateTime?
  deactivated_by      Int?
  updated_by          Int?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  solicitacoes_criadas        Solicitacao[]          @relation("SolicitacaoCriador")
  solicitacoes_atribuidas     Solicitacao[]          @relation("SolicitacaoOrcamentista")
  propostas_tecnicas          PropostaTecnica[]
  propostas_comerciais        PropostaComercial[]
  propostas_fabricacao        PropostaFabricacao[]
  solicitacoes_info           SolicitacaoInfo[]
  acordos                     Acordo[]
  notas_fiscais               NotaFiscal[]
  notificacoes                Notificacao[]
  contratos_responsavel       Contrato[]             @relation("ContratoResponsavel")
  contratos_criados           Contrato[]             @relation("ContratoCriador")
  hh_lancamentos              HhLancamento[]         @relation("HhLancamentoCriador")
  hh_realizados               HhRealizado[]          @relation("HhRealizadoCriador")
  fabricacao_itens_criados    FabricacaoItem[]       @relation("FabricacaoItemCriador")
  fabricacao_realizados       FabricacaoRealizado[]  @relation("FabricacaoRealizadoCriador")
  fabricacao_item_historico   FabricacaoItemHistorico[] @relation("FabItemHistCriador")
  hh_acomp_historico          HhAcompanhamentoHistorico[] @relation("HhAcompHistCriador")
  subindices_criados          SubIndiceFaturamento[] @relation("SubIndiceCriador")
  nfs_contratos_criadas       NotaFiscalContrato[]   @relation("NFContratoCriador")
  consolidados_criados        ConsolidadoMes[]       @relation("ConsolidadoCriador")
  historico_subindices        HistoricoSubIndice[]   @relation("HistSubIndiceCriador")
  historico_contratos         HistoricoContrato[]    @relation("HistContratoCriador")
  ocorrencias_criadas         OcorrenciaContratual[] @relation("OcorrenciaCriador")
  multas_criadas              MultaPenalidade[]      @relation("MultaCriador")
  historico_solicitacoes      HistoricoSolicitacao[] @relation("HistSolicitacaoCriador")
  subindices_comentario       SubIndiceFaturamento[] @relation("SubIndiceComentarioAutor")
  alteracoes_responsavel      PrevisaoAlteracao[]            @relation("AlteracaoResponsavel")
  alteracoes_revisor          PrevisaoAlteracao[]            @relation("AlteracaoRevisor")
  alteracoes_criadas          PrevisaoAlteracao[]            @relation("AlteracaoCriador")
  analista_critico_historicos AnalistaCriticoHistorico[]     @relation("AnalistaCriticoUser")
  analista_critico_execucoes  AnalistaCriticoHistorico[]     @relation("AnalistaCriticoExecutor")
  relatorios_criados          RelatorioSalvo[]               @relation("RelatorioCriador")
  relatorios_versoes          RelatorioVersao[]              @relation("RelatorioVersaoAutor")
  revisoes_criadas            RevisaoPendente[]              @relation("RevisaoPendenteCriador")
  relatorios_os_criados       RelatorioOS[]                  @relation("RelatorioOSCriador")
  revisoes_avaliadas          RevisaoPendente[]              @relation("RevisaoPendenteAvaliador")

  @@map("users")
}

model Cliente {
  id               Int          @id @default(autoincrement())
  codigo           String?      @unique
  nome             String
  cnpj             String?
  contato_nome     String?
  contato_email    String?
  contato_telefone String?
  cidade           String?
  estado           String?      @db.VarChar(2)
  ramo_atuacao     RamoAtuacao?
  segmento         Segmento?
  ativo            Boolean      @default(true)
  deactivated_at   DateTime?
  deactivated_by   Int?
  updated_by       Int?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  created_by       Int

  solicitacoes            Solicitacao[] @relation("SolicitacaoCliente")
  solicitacoes_como_final Solicitacao[] @relation("SolicitacaoClienteFinal")
  acordos                 Acordo[]
  contratos               Contrato[]    @relation("ContratoCliente")
  contratos_como_final    Contrato[]    @relation("ContratoClienteFinal")
  filiais                 Filial[]
  relatorios_os_faturamento RelatorioOS[] @relation("RelatorioOSClienteFat")

  @@map("clientes")
}

model Filial {
  id         Int      @id @default(autoincrement())
  cliente_id Int
  nome       String?
  cidade     String
  estado     String   @db.VarChar(2)
  ativo      Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  created_by Int

  cliente Cliente @relation(fields: [cliente_id], references: [id])

  @@index([cliente_id])
  @@map("filiais")
}

model Solicitacao {
  id              Int               @id @default(autoincrement())
  numero          String            @unique
  cliente_id      Int
  cliente_final_id             Int?
  data_recebimento             DateTime?
  segmento                     Segmento?
  contato         String?
  referencia_cliente           String?
  comprador                    String?
  telefone_comprador           String?
  email_comprador              String?
  cidade          String?
  estado          String?           @db.VarChar(2)
  origem          Origem?
  escopo          String?
  classificacao   Classificacao?
  interesse       Interesse?
  status          StatusSolicitacao @default(AGUARDANDO_ANALISE)
  status_analise  StatusAnalise     @default(AGUARDANDO)
  prazo_tecnica   DateTime?
  prazo_tecnica_indeterminado  Boolean @default(false)
  prazo_comercial DateTime?
  prazo_comercial_indeterminado Boolean @default(false)
  orcamentista_id Int?
  visita_tecnica    Boolean           @default(false)
  data_visita       DateTime?
  // Portal: solicitação vinda de portal do cliente, com data+hora de fechamento
  is_portal         Boolean           @default(false)
  portal_hora       String?           @db.VarChar(5) // legado (só hora) — usar portal_fechamento
  portal_fechamento DateTime?
  motivo_recusa     String?
  motivo_reprovacao            MotivoReprovacao?
  obs_reprovacao               String?
  revisao_esperada  Int               @default(1)
  as_sold           Boolean           @default(false)
  created_at        DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  created_by      Int
  cancelled_at    DateTime?
  cancel_reason   String?
  suspended_at    DateTime?
  suspend_reason  String?
  // Cancelamento da PROPOSTA (aba Propostas) — reversível, não afeta a solicitação
  proposta_cancelada_at    DateTime?
  proposta_cancel_reason   String?
  data_atribuicao DateTime?

  cliente        Cliente  @relation("SolicitacaoCliente", fields: [cliente_id], references: [id])
  cliente_final  Cliente? @relation("SolicitacaoClienteFinal", fields: [cliente_final_id], references: [id])
  orcamentista User?    @relation("SolicitacaoOrcamentista", fields: [orcamentista_id], references: [id])
  criador      User     @relation("SolicitacaoCriador", fields: [created_by], references: [id])

  propostas_tecnicas   PropostaTecnica[]
  propostas_comerciais PropostaComercial[]
  propostas_fabricacao PropostaFabricacao[]
  contratos            Contrato[]
  solicitacoes_info    SolicitacaoInfo[]
  historico            HistoricoSolicitacao[]
  revisoes_pendentes   RevisaoPendente[]
  relatorio_os         RelatorioOS?

  @@index([cliente_id])
  @@index([cliente_final_id])
  @@index([orcamentista_id])
  @@index([status])
  @@index([created_at])
  @@index([cancelled_at])
  @@index([status_analise])
  @@map("solicitacoes")
}

model HistoricoSolicitacao {
  id             Int      @id @default(autoincrement())
  solicitacao_id Int
  campo          String
  valor_de       String?
  valor_para     String?
  created_at     DateTime @default(now())
  created_by     Int

  solicitacao Solicitacao @relation(fields: [solicitacao_id], references: [id], onDelete: Cascade)
  usuario     User        @relation("HistSolicitacaoCriador", fields: [created_by], references: [id])

  @@index([solicitacao_id])
  @@map("historico_solicitacoes")
}

// M11: rastreabilidade de atribuição/remoção de Analista Crítico
model AnalistaCriticoHistorico {
  id            Int      @id @default(autoincrement())
  user_id       Int      // usuário que recebeu/perdeu o papel
  acao          String   // ATRIBUIDO | REMOVIDO
  realizado_por Int      // admin que executou a mudança
  created_at    DateTime @default(now())

  usuario   User @relation("AnalistaCriticoUser",     fields: [user_id],       references: [id])
  executor  User @relation("AnalistaCriticoExecutor", fields: [realizado_por], references: [id])

  @@index([user_id])
  @@map("analista_critico_historico")
}

model Notificacao {
  id         Int      @id @default(autoincrement())
  user_id    Int
  titulo     String
  mensagem   String
  lida       Boolean  @default(false)
  link       String?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([lida])
  @@map("notificacoes")
}

model PropostaTecnica {
  id               Int      @id @default(autoincrement())
  solicitacao_id   Int
  versao           Int
  hh_direto        Int?
  hh_indireto      Int?
  peso_montagem    Decimal? @db.Decimal(10, 2)
  // Campos exclusivos de Paradas
  efetivo_pico     Int?
  dias_parada      Int?
  hh_total         Int?
  turno            String?
  finais_de_semana Boolean?
  // Campos exclusivos de Obras (pesos por categoria)
  peso_equipamentos  Decimal? @db.Decimal(10, 3)
  peso_tubulacoes    Decimal? @db.Decimal(10, 3)
  peso_suportes      Decimal? @db.Decimal(10, 3)
  peso_estruturas    Decimal? @db.Decimal(10, 3)
  nao_aplicavel      Boolean  @default(false)
  data_base          DateTime?
  data_envio         DateTime?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  created_by       Int

  solicitacao          Solicitacao         @relation(fields: [solicitacao_id], references: [id])
  criador              User                @relation(fields: [created_by], references: [id])
  propostas_comerciais PropostaComercial[]

  @@unique([solicitacao_id, versao])
  @@index([solicitacao_id])
  @@map("propostas_tecnicas")
}

model PropostaComercial {
  id                      Int          @id @default(autoincrement())
  solicitacao_id          Int
  proposta_tecnica_id     Int?
  versao                  Int
  nao_aplicavel           Boolean      @default(false)
  valor_montagem_mecanica Decimal?     @db.Decimal(15, 2)
  possui_terceiros        Boolean      @default(false)
  valor_eletrica          Decimal?     @db.Decimal(15, 2)
  valor_isolamento        Decimal?     @db.Decimal(15, 2)
  valor_civil             Decimal?     @db.Decimal(15, 2)
  valor_hidraulica        Decimal?     @db.Decimal(15, 2)
  valor_fibra             Decimal?     @db.Decimal(15, 2)
  valor_tijolo_antiacido  Decimal?     @db.Decimal(15, 2)
  valor_outros_terceiros  Decimal?     @db.Decimal(15, 2)
  possui_fabricacao       Boolean      @default(false)
  valor_fabricacao        Decimal?     @db.Decimal(15, 2)
  peso_fabricacao         Decimal?     @db.Decimal(10, 3)
  valor_terceiros         Decimal?     @db.Decimal(15, 2)
  valor_total             Decimal?     @db.Decimal(15, 2)
  data_base               DateTime?
  data_envio              DateTime?
  resultado               String?
  motivo_perda            MotivoPerda?
  created_at              DateTime     @default(now())
  updated_at              DateTime     @updatedAt
  created_by              Int

  solicitacao      Solicitacao      @relation(fields: [solicitacao_id], references: [id])
  proposta_tecnica PropostaTecnica? @relation(fields: [proposta_tecnica_id], references: [id])
  criador          User             @relation(fields: [created_by], references: [id])

  @@index([solicitacao_id])
  @@map("propostas_comerciais")
}

model PropostaFabricacao {
  id               Int                    @id @default(autoincrement())
  solicitacao_id   Int
  versao           Int
  possui_testes    Boolean                @default(false)
  descricao_testes String?
  valor_testes     Decimal?               @db.Decimal(15, 2)
  possui_montagem  Boolean                @default(false)
  valor_montagem   Decimal?               @db.Decimal(15, 2)
  peso_total       Decimal                @db.Decimal(10, 3)
  valor_total      Decimal                @db.Decimal(15, 2)
  data_base        DateTime?
  data_envio       DateTime?
  resultado        String?
  motivo_perda     MotivoPerda?
  created_at       DateTime               @default(now())
  updated_at       DateTime               @updatedAt
  created_by       Int

  solicitacao  Solicitacao            @relation(fields: [solicitacao_id], references: [id])
  criador      User                   @relation(fields: [created_by], references: [id])
  equipamentos EquipamentoFabricacao[]

  @@unique([solicitacao_id, versao])
  @@index([solicitacao_id])
  @@map("propostas_fabricacao")
}

model EquipamentoFabricacao {
  id                     Int                @id @default(autoincrement())
  proposta_fabricacao_id Int
  ordem                  Int
  descricao              String
  peso_ton               Decimal            @db.Decimal(10, 3)
  valor_total            Decimal            @db.Decimal(15, 2)
  hh_previsto            Int?
  observacoes            String?
  created_at             DateTime           @default(now())

  proposta_fabricacao PropostaFabricacao @relation(fields: [proposta_fabricacao_id], references: [id], onDelete: Cascade)

  @@index([proposta_fabricacao_id])
  @@map("equipamentos_fabricacao")
}

model SolicitacaoInfo {
  id             Int      @id @default(autoincrement())
  solicitacao_id Int
  // Código sequencial por solicitação (INF-0001...). Nullable: registros
  // automáticos (encerramento de revisão) não recebem código.
  codigo         String?
  data           DateTime
  comentario     String
  // Tipo da informação (REUNIAO_CALL, DEFINICAO_INTERNA, FEEDBACK_CLIENTE,
  // DEFINICAO_ESCOPO, CONCORRENCIA, OUTROS). Nullable para registros
  // automáticos (encerramento de revisão).
  tipo           String?
  // impacto: descontinuado (mantido só por histórico, não exibido)
  impacto        String[]
  versao         Int?
  // Lixeira: exclusão vira soft-delete recuperável por 15 dias
  deleted_at     DateTime?
  deleted_by     Int?
  created_at     DateTime @default(now())
  created_by     Int

  solicitacao Solicitacao @relation(fields: [solicitacao_id], references: [id])
  criador     User        @relation(fields: [created_by], references: [id])
  anexos      SolicitacaoInfoAnexo[]

  @@index([solicitacao_id])
  @@index([deleted_at])
  @@map("solicitacoes_info")
}

model SolicitacaoInfoAnexo {
  id         Int      @id @default(autoincrement())
  info_id    Int
  nome       String
  tipo       String   // mime/extensão
  url        String   // data URL (base64) ou URL externa
  tamanho    Int?
  created_at DateTime @default(now())

  info SolicitacaoInfo @relation(fields: [info_id], references: [id], onDelete: Cascade)

  @@index([info_id])
  @@map("solicitacoes_info_anexos")
}

model HhLancamento {
  id          Int      @id @default(autoincrement())
  contrato_id Int
  versao      Int      @default(1)
  data_inicio DateTime
  data_fim    DateTime
  motivo      String?
  created_at  DateTime @default(now())
  created_by  Int

  contrato Contrato        @relation(fields: [contrato_id], references: [id])
  criador  User            @relation("HhLancamentoCriador", fields: [created_by], references: [id])
  meses    HhLancamentoMes[]

  @@unique([contrato_id, versao])
  @@index([contrato_id])
  @@map("hh_lancamentos")
}

model HhLancamentoMes {
  id            Int  @id @default(autoincrement())
  lancamento_id Int
  mes           Int
  ano           Int
  hh_previsto   Int?
  hh_planejado  Int?

  lancamento HhLancamento @relation(fields: [lancamento_id], references: [id], onDelete: Cascade)

  @@unique([lancamento_id, mes, ano])
  @@index([lancamento_id])
  @@map("hh_lancamento_mes")
}

model HhRealizado {
  id           Int      @id @default(autoincrement())
  contrato_id  Int
  mes          Int
  ano          Int
  hh_realizado Int
  observacoes  String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  created_by   Int

  contrato Contrato @relation(fields: [contrato_id], references: [id])
  criador  User     @relation("HhRealizadoCriador", fields: [created_by], references: [id])

  @@unique([contrato_id, mes, ano])
  @@index([contrato_id])
  @@map("hh_realizado")
}

// ── Fabricações: HH por ITEM (descrição, peso, datas) ────────────────────────
model FabricacaoItem {
  id          Int      @id @default(autoincrement())
  contrato_id Int
  descricao   String
  peso_total  Decimal? @db.Decimal(14, 2)
  data_inicio DateTime
  data_fim    DateTime
  ordem       Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  created_by  Int

  contrato   Contrato              @relation(fields: [contrato_id], references: [id])
  criador    User                  @relation("FabricacaoItemCriador", fields: [created_by], references: [id])
  meses      FabricacaoItemMes[]
  realizados FabricacaoRealizado[]
  historico  FabricacaoItemHistorico[]

  @@index([contrato_id])
  @@map("fabricacao_itens")
}

// HH orçado/previsto planejado por mês para cada item (habilitado pelo intervalo de datas)
model FabricacaoItemMes {
  id            Int      @id @default(autoincrement())
  item_id       Int
  mes           Int
  ano           Int
  hh_orcado     Int?
  hh_previsto   Int?
  peso_previsto Decimal? @db.Decimal(14, 2)

  item FabricacaoItem @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@unique([item_id, mes, ano])
  @@index([item_id])
  @@map("fabricacao_item_mes")
}

// Realizado lançado por mês: HH realizado + peso realizado (% de avanço = realizado/previsto, calculado)
model FabricacaoRealizado {
  id             Int      @id @default(autoincrement())
  item_id        Int
  mes            Int
  ano            Int
  hh_realizado   Int?
  peso_realizado Decimal? @db.Decimal(14, 2)
  observacoes    String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  created_by     Int

  item    FabricacaoItem @relation(fields: [item_id], references: [id], onDelete: Cascade)
  criador User           @relation("FabricacaoRealizadoCriador", fields: [created_by], references: [id])

  @@unique([item_id, mes, ano])
  @@index([item_id])
  @@map("fabricacao_realizado")
}

// Histórico de alterações de um item de Fabricação (cadastro e lançamentos)
model FabricacaoItemHistorico {
  id         Int      @id @default(autoincrement())
  item_id    Int
  campo      String
  valor_de   String?
  valor_para String?
  created_at DateTime @default(now())
  created_by Int

  item    FabricacaoItem @relation(fields: [item_id], references: [id], onDelete: Cascade)
  usuario User           @relation("FabItemHistCriador", fields: [created_by], references: [id])

  @@index([item_id])
  @@map("fabricacao_item_historico")
}

model ParadaHhConfig {
  id                     Int      @id @default(autoincrement())
  contrato_id            Int      @unique

  // Datas das etapas
  prep_inicio            DateTime?
  prep_fim               DateTime?
  parada_inicio          DateTime?
  parada_fim             DateTime?
  acomp_inicio           DateTime?
  acomp_fim              DateTime?

  // Horas adicionais - pico calculado automaticamente da grade da Parada
  mob_ativo              Boolean  @default(false)
  mob_dias_prev          Decimal? @db.Decimal(5, 1)
  mob_dias_real          Decimal? @db.Decimal(5, 1)

  desmob_ativo           Boolean  @default(false)
  desmob_dias_prev       Decimal? @db.Decimal(5, 1)
  desmob_dias_real       Decimal? @db.Decimal(5, 1)

  integ_ativo            Boolean  @default(false)
  integ_dias_prev        Decimal? @db.Decimal(5, 1)
  integ_dias_real        Decimal? @db.Decimal(5, 1)

  folga_ativo            Boolean  @default(false)
  folga_dias_prev        Decimal? @db.Decimal(5, 1)
  folga_dias_real        Decimal? @db.Decimal(5, 1)
  folga_pessoas_prev     Int?
  folga_pessoas_real     Int?

  // Análise financeira — coluna "Previsto" (Orçado e Real vêm do faturamento)
  fin_prev_valor_servico Decimal? @db.Decimal(15, 2)
  fin_prev_ase           Decimal? @db.Decimal(15, 2)

  // UCR — limites em R$/HH por faixa (preenchidos no cadastro)
  ucr_nao_suficiente     Decimal  @default(161.98) @db.Decimal(10, 2)
  ucr_a_evoluir          Decimal  @default(162.00) @db.Decimal(10, 2)
  ucr_bom                Decimal  @default(180.00) @db.Decimal(10, 2)
  ucr_otimo              Decimal  @default(234.00) @db.Decimal(10, 2)
  ucr_esplendido         Decimal  @default(270.00) @db.Decimal(10, 2)

  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  contrato               Contrato         @relation(fields: [contrato_id], references: [id])
  dias                   ParadaHhDia[]

  @@map("parada_hh_config")
}

model ParadaHhDia {
  id               Int      @id @default(autoincrement())
  config_id        Int
  etapa            String   // PREPARATIVO | PARADA | ACOMP_DESMOB
  data             DateTime @db.Date

  efetivo_plan     Int?
  horas_dia_plan   Decimal? @db.Decimal(5, 2) @default(9.8)
  hh_plan          Decimal? @db.Decimal(10, 2)
  efetivo_real     Int?
  horas_dia_real   Decimal? @db.Decimal(5, 2) @default(9.8)
  hh_real          Decimal? @db.Decimal(10, 2)

  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  config           ParadaHhConfig @relation(fields: [config_id], references: [id])

  @@unique([config_id, etapa, data])
  @@index([config_id])
  @@index([config_id, etapa])
  @@map("parada_hh_dia")
}

model Acordo {
  id                      Int          @id @default(autoincrement())
  numero                  String       @unique
  cliente_id              Int
  descricao               String?
  valor_total             Decimal      @db.Decimal(15, 2)
  ano                     Int
  valor_anos_seguintes    Decimal?     @db.Decimal(15, 2)
  status                  StatusAcordo @default(ATIVO)
  data_inicio             DateTime?
  data_fim                DateTime?
  created_at              DateTime     @default(now())
  updated_at              DateTime     @updatedAt
  created_by              Int
  cancelled_at            DateTime?
  cancel_reason           String?

  cliente       Cliente      @relation(fields: [cliente_id], references: [id])
  criador       User         @relation(fields: [created_by], references: [id])
  notas_fiscais NotaFiscal[]

  @@index([cliente_id])
  @@index([ano])
  @@index([status])
  @@index([cancelled_at])
  @@map("acordos")
}

model NotaFiscal {
  id                Int      @id @default(autoincrement())
  acordo_id         Int
  numero_nf         String
  valor             Decimal  @db.Decimal(15, 2)
  data_emissao      DateTime
  data_vencimento   DateTime
  ativa             Boolean  @default(true)
  motivo_inativacao String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  created_by        Int

  acordo  Acordo @relation(fields: [acordo_id], references: [id])
  criador User   @relation(fields: [created_by], references: [id])

  @@index([acordo_id])
  @@map("notas_fiscais")
}

// ─── Módulo Controle de Faturamento ──────────────────────────────────────────

model Contrato {
  id             Int               @id @default(autoincrement())
  indice         String            @unique
  ano_referencia Int
  status         StatusFaturamento @default(A_FATURAR)
  cliente_id     Int
  num_os         String?
  num_acordo     String?
  num_proposta   String?
  solicitacao_id    Int?
  responsavel_id    Int?
  cliente_final_id  Int?
  cidade            String?
  estado            String?          @db.VarChar(2)
  data_inicio    DateTime?
  data_fim       DateTime?
  descricao      String?
  classificacao  Classificacao?
  valor_contrato Decimal?       @db.Decimal(15, 2)
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  created_by     Int
  cancelled_at   DateTime?
  cancel_reason  String?
  rascunho       Boolean               @default(false)
  // Lixeira: exclusão do Controle de Faturamento vira soft-delete restaurável por 15 dias
  deleted_at     DateTime?
  deleted_by     Int?
  // Soft-cancel do acompanhamento de HH (Obras/Paradas) — RN-18 (não exclui, cancela com motivo)
  hh_cancelado_at   DateTime?
  hh_cancel_motivo  String?
  hh_cancelado_por  Int?

  cliente        Cliente                @relation("ContratoCliente", fields: [cliente_id], references: [id])
  cliente_final  Cliente?               @relation("ContratoClienteFinal", fields: [cliente_final_id], references: [id])
  responsavel    User?                  @relation("ContratoResponsavel", fields: [responsavel_id], references: [id])
  criador        User                   @relation("ContratoCriador", fields: [created_by], references: [id])
  solicitacao    Solicitacao?           @relation(fields: [solicitacao_id], references: [id])
  subindices     SubIndiceFaturamento[]
  historico      HistoricoContrato[]
  hh_lancamentos   HhLancamento[]
  hh_realizados    HhRealizado[]
  hh_acomp_historico HhAcompanhamentoHistorico[]
  fabricacao_itens FabricacaoItem[]
  parada_hh_config ParadaHhConfig?
  ocorrencias    OcorrenciaContratual[]
  multas         MultaPenalidade[]

  @@index([cliente_id])
  @@index([cliente_final_id])
  @@index([solicitacao_id])
  @@index([ano_referencia])
  @@index([status])
  @@index([cancelled_at])
  @@index([hh_cancelado_at])
  @@map("contratos")
}

// Histórico de remoção/reativação do acompanhamento de HH (RN-18: rastreabilidade)
model HhAcompanhamentoHistorico {
  id          Int      @id @default(autoincrement())
  contrato_id Int
  acao        String   // CANCELADO | REATIVADO
  motivo      String?
  created_at  DateTime @default(now())
  created_by  Int

  contrato Contrato @relation(fields: [contrato_id], references: [id], onDelete: Cascade)
  usuario  User     @relation("HhAcompHistCriador", fields: [created_by], references: [id])

  @@index([contrato_id])
  @@map("hh_acompanhamento_historico")
}

model HistoricoContrato {
  id          Int      @id @default(autoincrement())
  contrato_id Int
  campo       String
  valor_de    String?
  valor_para  String?
  created_at  DateTime @default(now())
  created_by  Int

  contrato Contrato @relation(fields: [contrato_id], references: [id], onDelete: Cascade)
  usuario  User     @relation("HistContratoCriador", fields: [created_by], references: [id])

  @@index([contrato_id])
  @@map("historico_contratos")
}

// ─── Ocorrências Contratuais (gestão de acontecimentos durante o contrato) ────
model OcorrenciaContratual {
  id                     Int      @id @default(autoincrement())
  contrato_id            Int
  codigo                 String   // ex.: OC-0001 (sequencial por contrato)
  tipo                   String   // ver TIPOS em src/lib/ocorrencias.ts
  data                   DateTime // data do evento
  responsabilidade       String   // CLIENTE | FORCA_MAIOR | IMETAME | TERCEIROS
  impacto                String[] // PRAZO | CUSTO | CRONOGRAMA | MARCO_CONTRATUAL | OUTROS
  descricao              String
  data_notificacao_cliente DateTime?
  // Lixeira: exclusão vira soft-delete recuperável por 15 dias
  deleted_at             DateTime?
  deleted_by             Int?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt
  created_by             Int

  contrato Contrato            @relation(fields: [contrato_id], references: [id], onDelete: Cascade)
  criador  User               @relation("OcorrenciaCriador", fields: [created_by], references: [id])
  anexos   OcorrenciaAnexo[]

  @@unique([contrato_id, codigo])
  @@index([contrato_id])
  @@index([data])
  @@index([deleted_at])
  @@map("ocorrencias_contratuais")
}

// ─── Multas / Penalidades (movimentações financeiras do contrato) ─────────────
model MultaPenalidade {
  id                       Int      @id @default(autoincrement())
  contrato_id              Int
  tipo                     String   // MULTA | GLOSAS | REEMBOLSOS | OUTROS
  descricao                String
  data_ocorrencia          DateTime
  data_notificacao_cliente DateTime?
  data_desconto            DateTime?
  valor_total              Decimal  @db.Decimal(15, 2)
  ativa                    Boolean  @default(true)
  motivo_inativacao        String?
  // Lixeira: exclusão vira soft-delete recuperável por 15 dias
  deleted_at               DateTime?
  deleted_by               Int?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt
  created_by               Int

  contrato Contrato @relation(fields: [contrato_id], references: [id], onDelete: Cascade)
  criador  User     @relation("MultaCriador", fields: [created_by], references: [id])

  @@index([contrato_id])
  @@index([data_ocorrencia])
  @@index([deleted_at])
  @@map("multas_penalidades")
}

model OcorrenciaAnexo {
  id            Int      @id @default(autoincrement())
  ocorrencia_id Int
  nome          String
  tipo          String   // mime/extensão (ex.: application/pdf, image/png)
  url           String
  tamanho       Int?     // bytes
  created_at    DateTime @default(now())

  ocorrencia OcorrenciaContratual @relation(fields: [ocorrencia_id], references: [id], onDelete: Cascade)

  @@index([ocorrencia_id])
  @@map("ocorrencias_anexos")
}

model SubIndiceFaturamento {
  id          Int               @id @default(autoincrement())
  contrato_id Int
  ordem       Int
  descricao   String
  valor_total Decimal           @db.Decimal(15, 2)
  data_inicio DateTime?
  data_fim    DateTime?
  num_os                   String?
  comentarios              String?
  comentario_updated_at    DateTime?
  comentario_updated_by    Int?
  jan         Decimal?          @db.Decimal(15, 2)
  fev         Decimal?          @db.Decimal(15, 2)
  mar         Decimal?          @db.Decimal(15, 2)
  abr         Decimal?          @db.Decimal(15, 2)
  mai         Decimal?          @db.Decimal(15, 2)
  jun         Decimal?          @db.Decimal(15, 2)
  jul         Decimal?          @db.Decimal(15, 2)
  ago         Decimal?          @db.Decimal(15, 2)
  set         Decimal?          @db.Decimal(15, 2) @map("set_col")
  out         Decimal?          @db.Decimal(15, 2)
  nov         Decimal?          @db.Decimal(15, 2)
  dez         Decimal?          @db.Decimal(15, 2)
  // Lixeira: exclusão vira soft-delete recuperável por 15 dias
  deleted_at  DateTime?
  deleted_by  Int?
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  created_by  Int

  contrato             Contrato             @relation(fields: [contrato_id], references: [id], onDelete: Cascade)
  criador              User                 @relation("SubIndiceCriador", fields: [created_by], references: [id])
  comentario_autor     User?                @relation("SubIndiceComentarioAutor", fields: [comentario_updated_by], references: [id])
  notas_fiscais        NotaFiscalContrato[]
  consolidados         ConsolidadoMesItem[]
  historico            HistoricoSubIndice[]
  alteracoes           PrevisaoAlteracao[]

  @@index([contrato_id])
  @@index([deleted_at])
  @@map("subindices_faturamento")
}

model HistoricoSubIndice {
  id           Int      @id @default(autoincrement())
  subindice_id Int
  campo        String
  valor_de     String?
  valor_para   String?
  created_at   DateTime @default(now())
  created_by   Int

  subindice SubIndiceFaturamento @relation(fields: [subindice_id], references: [id], onDelete: Cascade)
  usuario   User                 @relation("HistSubIndiceCriador", fields: [created_by], references: [id])

  @@index([subindice_id])
  @@map("historico_subindices")
}

model NotaFiscalContrato {
  id                Int      @id @default(autoincrement())
  subindice_id      Int
  numero_nf         String
  valor_total_nf    Decimal  @db.Decimal(15, 2)
  percentual        Decimal  @db.Decimal(5, 2) @default(100)
  valor_atribuido   Decimal  @db.Decimal(15, 2)
  data_emissao      DateTime
  data_vencimento   DateTime
  ativa             Boolean  @default(true)
  motivo_inativacao String?
  tipo_documento    String?  @default("NF")
  // Fluxo de aprovação de lançamento de faturamento (responsável -> coordenação)
  status_aprovacao  String   @default("APROVADO") // APROVADO | PENDENTE | REPROVADO
  solicitado_por    Int?
  revisado_por      Int?
  revisado_em       DateTime?
  motivo_recusa     String?
  // Lixeira: exclusão vira soft-delete recuperável por 15 dias
  deleted_at        DateTime?
  deleted_by        Int?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  created_by        Int

  subindice SubIndiceFaturamento @relation(fields: [subindice_id], references: [id], onDelete: Cascade)
  criador   User                 @relation("NFContratoCriador", fields: [created_by], references: [id])

  @@index([subindice_id])
  @@index([numero_nf, ativa])
  @@index([status_aprovacao])
  @@index([deleted_at])
  @@map("notas_fiscais_contratos")
}

// ─── Consolidado Mensal (Previsão x Realizado) ────────────────────────────────

model ConsolidadoMes {
  id           Int       @id @default(autoincrement())
  mes          Int       // 1-12
  ano          Int
  arquivado_at DateTime? // RN-CF-12: null = ativo; preenchido = arquivado
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  created_by   Int

  criador User                 @relation("ConsolidadoCriador", fields: [created_by], references: [id])
  itens   ConsolidadoMesItem[]

  @@index([mes, ano])
  @@index([ano])
  @@map("consolidados_mes")
}

model ConsolidadoMesItem {
  id             Int     @id @default(autoincrement())
  consolidado_id Int
  subindice_id   Int
  valor_previsto Decimal @db.Decimal(15, 2)

  consolidado ConsolidadoMes       @relation(fields: [consolidado_id], references: [id], onDelete: Cascade)
  subindice   SubIndiceFaturamento @relation(fields: [subindice_id], references: [id], onDelete: Cascade)

  @@index([consolidado_id])
  @@index([subindice_id])
  @@map("consolidados_mes_itens")
}

// ─── Workflow de aprovação de previsão ────────────────────────────────────────

enum StatusAlteracaoPrevisao {
  PENDENTE
  APROVADO
  REPROVADO
}

model PrevisaoAlteracao {
  id             Int                     @id @default(autoincrement())
  subindice_id   Int
  responsavel_id Int
  status         StatusAlteracaoPrevisao @default(PENDENTE)
  motivo_recusa  String?
  revisor_id     Int?
  reviewed_at    DateTime?

  jan_de   Decimal? @db.Decimal(15, 2)
  fev_de   Decimal? @db.Decimal(15, 2)
  mar_de   Decimal? @db.Decimal(15, 2)
  abr_de   Decimal? @db.Decimal(15, 2)
  mai_de   Decimal? @db.Decimal(15, 2)
  jun_de   Decimal? @db.Decimal(15, 2)
  jul_de   Decimal? @db.Decimal(15, 2)
  ago_de   Decimal? @db.Decimal(15, 2)
  set_de   Decimal? @db.Decimal(15, 2)
  out_de   Decimal? @db.Decimal(15, 2)
  nov_de   Decimal? @db.Decimal(15, 2)
  dez_de   Decimal? @db.Decimal(15, 2)

  jan_para   Decimal? @db.Decimal(15, 2)
  fev_para   Decimal? @db.Decimal(15, 2)
  mar_para   Decimal? @db.Decimal(15, 2)
  abr_para   Decimal? @db.Decimal(15, 2)
  mai_para   Decimal? @db.Decimal(15, 2)
  jun_para   Decimal? @db.Decimal(15, 2)
  jul_para   Decimal? @db.Decimal(15, 2)
  ago_para   Decimal? @db.Decimal(15, 2)
  set_para   Decimal? @db.Decimal(15, 2)
  out_para   Decimal? @db.Decimal(15, 2)
  nov_para   Decimal? @db.Decimal(15, 2)
  dez_para   Decimal? @db.Decimal(15, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  created_by Int

  subindice   SubIndiceFaturamento @relation(fields: [subindice_id], references: [id], onDelete: Cascade)
  responsavel User                 @relation("AlteracaoResponsavel", fields: [responsavel_id], references: [id])
  revisor     User?                @relation("AlteracaoRevisor", fields: [revisor_id], references: [id])
  criador     User                 @relation("AlteracaoCriador", fields: [created_by], references: [id])

  @@index([subindice_id])
  @@index([responsavel_id])
  @@index([status])
  @@map("previsao_alteracoes")
}

// ─── Relatório de abertura de OS (preenchido quando a proposta é GANHA) ───────
// Limpo automaticamente se o resultado da proposta for alterado depois.
model RelatorioOS {
  id                     Int      @id @default(autoincrement())
  solicitacao_id         Int      @unique
  classificacao          String
  cliente_faturamento_id Int
  cliente_final          String?
  numero_solicitacao     String
  data_inicio            DateTime
  data_fim               DateTime
  responsavel_imetame    String
  local_realizacao       String
  gestor_cliente         String
  valor_estimado         Decimal  @db.Decimal(15, 2)
  escopo                 String
  unidade_medida         String   // KG | TON | PC | CJ
  quantidade             Decimal  @db.Decimal(12, 2)
  ncm                    String?
  pintura                Boolean
  retorno                Boolean
  memorial_calculo       Boolean
  material               String?  // IMETAME | TERCEIROS | AMBOS
  art                    Boolean
  databook               Boolean
  material_apoio         Boolean
  comentario             String?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt
  created_by             Int

  solicitacao         Solicitacao @relation(fields: [solicitacao_id], references: [id], onDelete: Cascade)
  cliente_faturamento Cliente     @relation("RelatorioOSClienteFat", fields: [cliente_faturamento_id], references: [id])
  criador             User        @relation("RelatorioOSCriador", fields: [created_by], references: [id])

  @@map("relatorios_os")
}

// ─── Revisões pendentes de avaliação do orçamentista ──────────────────────────
// Uma nova revisão só é aplicada à solicitação depois que o orçamentista
// confirmar que é de fato uma revisão; caso contrário é devolvida com
// justificativa. O payload guarda os dados informados na abertura.
model RevisaoPendente {
  id             Int       @id @default(autoincrement())
  solicitacao_id Int
  payload        Json
  status         String    @default("PENDENTE") // PENDENTE | APROVADA | RECUSADA
  justificativa  String?   // preenchida pelo orçamentista na devolução
  avaliado_por   Int?
  avaliado_em    DateTime?
  created_at     DateTime  @default(now())
  created_by     Int

  solicitacao Solicitacao @relation(fields: [solicitacao_id], references: [id], onDelete: Cascade)
  criador     User        @relation("RevisaoPendenteCriador", fields: [created_by], references: [id])
  avaliador   User?       @relation("RevisaoPendenteAvaliador", fields: [avaliado_por], references: [id])

  @@index([solicitacao_id])
  @@index([status])
  @@map("revisoes_pendentes")
}

// ─── Construtor de Relatório: relatórios salvos + versionamento ────────────────

model RelatorioSalvo {
  id         Int       @id @default(autoincrement())
  nome       String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  created_by Int
  deleted_at DateTime? // soft delete (RN-18)

  criador User              @relation("RelatorioCriador", fields: [created_by], references: [id])
  versoes RelatorioVersao[]

  @@index([created_by])
  @@index([deleted_at])
  @@map("relatorios_salvos")
}

model RelatorioVersao {
  id           Int      @id @default(autoincrement())
  relatorio_id Int
  versao       Int
  config       Json     // { modulo, linhas, colunas, valores, filtros }
  created_at   DateTime @default(now())
  created_by   Int

  relatorio RelatorioSalvo @relation(fields: [relatorio_id], references: [id], onDelete: Cascade)
  autor     User           @relation("RelatorioVersaoAutor", fields: [created_by], references: [id])

  @@unique([relatorio_id, versao])
  @@index([relatorio_id])
  @@map("relatorios_versoes")
}